# Override amd64's settings for ARM64 compatibility
# Note: Some packages and versions may differ on ARM64 architecture

tensorrt_version=8.6.0.12-1+cuda11.8
tensorrt_cuda_version=11.8

# NVIDIA CUDA Configuration
cuda_version=11.4
cuda_install_drivers=false

# cuDNN Configuration
cudnn_version=8.6.0.166-1+cuda11.4

# TensorRT Configuration (ARM64 compatible)
tensorrt_version=8.5.2-1+cuda11.4
tensorrt_cuda_version=11.4

# CUDA Configuration (ARM64 specific)
cuda_install_drivers=false

# Development Tools (ARM64 may have limited support)
install_ros_tools=true
install_system_tools=true
install_python_tools=true
install_code_quality_tools=false