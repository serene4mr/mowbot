{
    "name": "mowbot_dev",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": "..",
        "args": {
            "USERNAME": "${localEnv:USER}"
        },
        "options": [
            "-t", "mowbot_dev_cuda",
            "--pull=false",
            "--build-arg", "BASE_IMAGE=ghcr.io/serene4mr/mowbot:devel-amd64-latest"
        ]
    },
    "remoteUser": "${localEnv:USER}",
    "updateRemoteUserUID": true,
    "runArgs": [
        "--name", "mowbot_dev",
        "--net", "host",
        "--ipc", "host",
        "--pid", "host",
        "--privileged",
        "-v", "/dev:/dev",
        "-v", "/dev/shm:/dev/shm",
        "-v", "/tmp/.X11-unix:/tmp/.X11-unix",
        "-e", "DISPLAY"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python"
            ]
        }
    }
  }