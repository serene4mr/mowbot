# Overrides for Jetson (ARM64 + L4T) — sourced after env/amd64.env, not generic linux/arm64.
# Match the L4T / JetPack version on the target device.
base_image=ghcr.io/serene4mr/ros:humble-desktop-l4t-r36.4.0-fix
mowbot_platform_slug=jetson-l4t-r36.4

# CUDA is already part of L4T; skip NVIDIA install in ansible
prompt_install_nvidia=n

# TensorRT on ARM64/sbsa CUDA repo does not provide 10.8.x (+cuda12.8)
tensorrt_version=10.3.0.26-1+cuda12.5
tensorrt_cuda_version=12.5

# code_quality_tools have limited ARM64 support
install_code_quality_tools=false
